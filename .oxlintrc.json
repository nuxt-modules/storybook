{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "options": {
    "typeAware": true
    // "typeCheck": true
  },
  "plugins": [
    "eslint",
    "import",
    "unicorn",
    "typescript",
    "oxc",
    "vitest",
    "vue"
  ],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "error",
    "style": "warn"
  },
  "jsPlugins": ["@nuxt/eslint-plugin"],
  "overrides": [
    {
      "files": ["**/*.test-d.ts"],
      "rules": {
        "vitest/expect-expect": "off"
      }
    }
  ]
}
